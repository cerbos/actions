{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>cerbos/renovate"],
  "customManagers": [
    {
      "description": "https://github.com/renovatebot/renovate/issues/38067",
      "customType": "jsonata",
      "managerFilePatterns": ["/(^|/)package\\.json$/"],
      "fileFormat": "json",
      "matchStrings": [
        "{\"depName\": devEngines.packageManager.name, \"currentValue\": devEngines.packageManager.version, \"datasource\": \"npm\", \"versioning\": \"npm\"}",
        "{\"depName\": devEngines.runtime.name, \"currentValue\": devEngines.runtime.version, \"datasource\": devEngines.runtime.name, \"versioning\": devEngines.runtime.name}"
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions deps"
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "Go deps"
    },
    {
      "matchManagers": ["custom.jsonata", "nodenv", "npm"],
      "groupName": "npm deps"
    },
    {
      "matchPackageNames": ["cerbos/actions"],
      "enabled": false
    }
  ]
}
